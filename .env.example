# Groq API — gratuito su https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ElevenLabs TTS — https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=gfKKsLN1k0oYYN9n2dXX  # default: Violetta (italiana)

# GitHub — per upload MP3 e aggiornamento feed RSS
# Localmente: usa il tuo Personal Access Token (scope: repo)
# In GitHub Actions: viene iniettato automaticamente
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=smariani/wine-podcast-automation
