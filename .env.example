# Google Drive — service account JSON (tutto su una riga)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ElevenLabs TTS — https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=vh8ugQnSUeaDxwMfmFcx  # default: voce clonata

# GitHub — per upload MP3 e aggiornamento feed RSS
# Localmente: usa il tuo Personal Access Token (scope: repo)
# In GitHub Actions: viene iniettato automaticamente
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=smariani/wine-podcast-automation
